# Copy to .env (gitignored) and fill in. Paths stay on your machine — no secret
# content ever enters the repo.

# Absolute path to the BigQuery service-account JSON key on YOUR machine
GOOGLE_KEY_FILE=/absolute/path/to/your-service-account-key.json

# Admin token from the production host (Render → Environment → ADMIN_TOKEN).
# Optional: without it the DAG skips the production-load trigger and still runs
# the quality checks + view builds against the warehouse.
GEW_ADMIN_TOKEN=

# Optional overrides
GEW_BASE_URL=https://goodearthnews.org
BIGQUERY_DATASET=good_earth_news
