ANTHROPIC_API_KEY=your_anthropic_api_key_here
PORT=3001
# Secret required to call POST /api/fetch (the manual scrape trigger)
ADMIN_TOKEN=change_me_to_a_long_random_string
# BigQuery analytics warehouse (optional — pipeline is dormant without it).
# Paste the full service-account JSON as a single line:
GOOGLE_APPLICATION_CREDENTIALS_JSON=
BIGQUERY_DATASET=good_earth_news
